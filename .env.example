# Copy this file to .env and fill in the values you need.
# If you leave MODEL_PROVIDER=none, the app runs in retrieval-only demo mode
# (no API key required) — it will return the best-matching manual excerpt
# instead of a generated answer. Good enough for a first demo/pitch.

MODEL_PROVIDER=none
# MODEL_PROVIDER=anthropic
# MODEL_PROVIDER=openai

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Demo password for the "Internal Engineering" mode in app.py
# (placeholder only — replace with real auth in production)
INTERNAL_MODE_PASSWORD=employee123
